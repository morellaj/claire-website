---
import Layout from "../layouts/Layout.astro";
import { sortedVideos } from "../data/videos";

const videos = sortedVideos();
const pusheenImgs = ["/images/pusheen-3.gif", "/images/pusheen-1.gif", "/images/pusheen-2.gif", "/images/pusheen-4.gif"];
const capybaraImgs = ["/images/capybara-2.gif", "/images/capybara-4.gif", "/images/capybara-5.gif", "/images/capybara-3.gif"];
---
<Layout title="claire ♡ studio">
  <!-- Ambient drifting sparkles -->
  <div class="drift-layer" aria-hidden="true"></div>

  <section class="hero">
    <img
      class="hero-pusheen clickable-char"
      src={pusheenImgs[0]}
      data-images={JSON.stringify(pusheenImgs)}
      data-index="0"
      alt="click me!"
    />
    <div class="hero-text">
      <h1 class="welcome-title">
        <span class="typed" data-text="welcome to claire's studio!"></span>
        <span class="sparkle-emoji">✨</span>
      </h1>
      <p>slime, drawing, and all the fun stuff</p>
      <p class="tip">✨ psst... try clicking things. there are secrets! ✨</p>
    </div>
    <img
      class="hero-capybara clickable-char"
      src={capybaraImgs[0]}
      data-images={JSON.stringify(capybaraImgs)}
      data-index="0"
      alt="click me!"
    />
    <!-- Hidden heart #1: tucked in hero top-left -->
    <span class="hidden-heart" data-id="h1" style="top: 8px; left: 12px;">♡</span>
  </section>

  <!-- Ask Pusheen magic 8-ball -->
  <section class="magic8">
    <h2>🔮 ask pusheen</h2>
    <div class="magic8-row">
      <img src="/images/pusheen-3.gif" class="magic8-pusheen" alt="" />
      <div class="magic8-main">
        <input id="magic8-q" type="text" placeholder="ask a yes or no question..." maxlength="120" />
        <button id="magic8-btn">ask! ✨</button>
        <div id="magic8-answer" class="magic8-answer"></div>
      </div>
    </div>
  </section>

  <section class="videos">
    <h2>🎬 my videos</h2>
    <!-- Hidden heart #2: near section heading -->
    <span class="hidden-heart" data-id="h2" style="top: 0.5rem; right: 0.5rem;">♡</span>
    <div class="grid">
      {videos.map((v) => (
        <a href={`/videos/${v.slug}`} class="card">
          <div class="thumb">
            <img
              src={`https://img.youtube.com/vi/${v.youtubeId}/mqdefault.jpg`}
              alt={v.title}
              loading="lazy"
            />
            <span class="play">▶</span>
          </div>
          <div class="card-body">
            <h3>{v.title}</h3>
            <p class="desc">{v.description}</p>
            <p class="date">{new Date(v.date).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</p>
          </div>
          <span class="bow">🎀</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Hidden heart #3: hidden in the footer region of main -->
  <div class="heart3-holder">
    <span class="hidden-heart" data-id="h3">♡</span>
    <p class="heart-hint">find all 3 hidden hearts ♡ on this page!</p>
    <p class="heart-progress" id="heart-progress">0 / 3 found</p>
  </div>

  <!-- Rollerskating pusheen (zips across every 45s) -->
  <img id="skater" src="/images/pusheen-1.gif" alt="" aria-hidden="true" />

  <!-- Slime drip container (populated on code) -->
  <div id="slime-layer" aria-hidden="true"></div>
</Layout>

<style>
  /* --- Hero --- */
  .hero {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, #FFE8F3 0%, #FFC4DE 100%);
    border-radius: 24px;
    padding: 2rem 1.5rem;
    margin: 1rem 0 2.5rem;
    border: 3px dashed var(--pink-accent);
    position: relative;
    overflow: hidden;
  }
  .hero::before, .hero::after {
    content: "⭐";
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.5;
  }
  .hero::before { top: 10px; left: 20px; }
  .hero::after { bottom: 10px; right: 20px; }
  .hero-pusheen, .hero-capybara { width: 110px; height: auto; }
  .clickable-char { cursor: pointer; transition: transform 200ms ease; }
  .clickable-char:hover { transform: scale(1.1) rotate(-5deg); }
  .clickable-char:active { transform: scale(0.9); }
  .hero-text { text-align: center; }
  .hero-text h1 {
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    line-height: 1.1;
    color: var(--pink-accent);
    text-shadow: 3px 3px 0 #fff;
    min-height: 2.6rem;
  }
  .typed::after {
    content: "|";
    animation: blink 1s step-end infinite;
    color: var(--pink-accent);
  }
  .typed.done::after { content: ""; }
  @keyframes blink { 50% { opacity: 0; } }
  .sparkle-emoji {
    display: inline-block;
    animation: spin 4s linear infinite;
    margin-left: 0.25rem;
  }
  @keyframes spin {
    from { transform: rotate(0); }
    to { transform: rotate(360deg); }
  }
  .hero-text p {
    font-family: "Fredoka", sans-serif;
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0;
  }
  .tip {
    font-size: 0.95rem !important;
    opacity: 0.75;
    margin-top: 0.6rem !important;
    font-style: italic;
  }
  @media (max-width: 640px) {
    .hero { grid-template-columns: 1fr; text-align: center; }
    .hero-pusheen, .hero-capybara { width: 90px; margin: 0 auto; }
    .hero-text h1 { font-size: 1.8rem; }
  }

  /* --- Magic 8-ball --- */
  .magic8 {
    background: linear-gradient(135deg, #FFF 0%, #FFE4F3 100%);
    border: 3px solid var(--pink-accent);
    border-radius: 20px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
    box-shadow: 0 6px 0 var(--pink-bubble);
  }
  .magic8 h2 { margin: 0 0 0.75rem; font-size: 1.5rem; }
  .magic8-row { display: flex; gap: 1rem; align-items: center; }
  .magic8-pusheen { width: 80px; flex-shrink: 0; }
  .magic8-main { flex: 1; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
  #magic8-q {
    flex: 1;
    min-width: 160px;
    padding: 0.6rem 0.9rem;
    border-radius: 999px;
    border: 2px solid var(--pink-bubble);
    font-family: "Quicksand", sans-serif;
    font-size: 1rem;
    background: #fff;
    outline: none;
  }
  #magic8-q:focus { border-color: var(--pink-accent); }
  #magic8-btn {
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    border: 0;
    background: var(--pink-accent);
    color: white;
    font-family: "Fredoka", sans-serif;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: 0 4px 0 #c13783;
  }
  #magic8-btn:hover { transform: translateY(-2px); }
  #magic8-btn:active { transform: translateY(2px); box-shadow: 0 0 0 #c13783; }
  .magic8-answer {
    flex-basis: 100%;
    min-height: 2rem;
    margin-top: 0.4rem;
    font-family: "Fredoka", sans-serif;
    font-weight: 600;
    color: var(--pink-accent);
    font-size: 1.1rem;
    text-align: center;
  }
  .magic8-answer.shake { animation: shake 0.5s ease-in-out; }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-8px) rotate(-2deg); }
    40% { transform: translateX(8px) rotate(2deg); }
    60% { transform: translateX(-6px); }
    80% { transform: translateX(6px); }
  }

  /* --- Videos --- */
  .videos { position: relative; }
  .videos h2 { font-size: 1.75rem; margin-bottom: 1rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .card {
    background: var(--cream);
    border-radius: 20px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border: 3px solid var(--pink-bubble);
    box-shadow: 0 6px 0 var(--pink-accent);
    transition: transform 150ms ease, box-shadow 150ms ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-4px) rotate(-1deg);
    box-shadow: 0 10px 0 var(--pink-accent);
  }
  .card:hover .bow { transform: rotate(15deg) scale(1.3); }
  .thumb { position: relative; aspect-ratio: 16 / 9; background: #000; }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .play {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    opacity: 0.85;
  }
  .card-body { padding: 1rem 1.1rem 1.2rem; flex: 1; }
  .card-body h3 { font-size: 1.15rem; margin: 0 0 0.4rem; color: var(--pink-accent); }
  .desc {
    font-size: 0.9rem; margin: 0 0 0.6rem;
    color: var(--ink); opacity: 0.8;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .date {
    font-size: 0.8rem; margin: 0;
    font-family: "Fredoka", sans-serif;
    color: var(--pink-accent); opacity: 0.75;
  }
  .bow {
    position: absolute; top: -8px; right: -8px;
    font-size: 1.8rem;
    transition: transform 200ms ease;
  }

  /* --- Hidden hearts --- */
  .hidden-heart {
    position: absolute;
    font-size: 1rem;
    color: #ff1f7a;
    opacity: 0.25;
    cursor: pointer;
    user-select: none;
    transition: transform 200ms ease, opacity 200ms ease;
    z-index: 5;
  }
  .hidden-heart:hover { transform: scale(1.5); opacity: 1; }
  .hidden-heart.found {
    animation: found-pop 500ms ease forwards;
    pointer-events: none;
  }
  @keyframes found-pop {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(2.5); opacity: 1; }
    100% { transform: scale(0); opacity: 0; }
  }
  .heart3-holder {
    position: relative;
    margin-top: 3rem;
    padding-top: 1rem;
    text-align: center;
    border-top: 1px dashed var(--pink-bubble);
  }
  .heart3-holder .hidden-heart {
    position: static;
    display: inline-block;
    font-size: 0.85rem;
    opacity: 0.2;
  }
  .heart-hint {
    font-family: "Fredoka", sans-serif;
    color: var(--pink-accent);
    opacity: 0.7;
    margin: 0.5rem 0 0.25rem;
  }
  .heart-progress {
    font-family: "Fredoka", sans-serif;
    font-weight: 600;
    color: var(--pink-accent);
    margin: 0;
  }

  /* --- Rollerskating Pusheen --- */
  #skater {
    position: fixed;
    bottom: 40px;
    left: -160px;
    width: 110px;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    filter: drop-shadow(0 4px 0 rgba(255, 79, 163, 0.4));
  }
  #skater.zoom {
    animation: skate 5s linear forwards;
  }
  @keyframes skate {
    0% { left: -160px; opacity: 1; transform: rotate(-5deg); }
    50% { transform: rotate(5deg); }
    100% { left: 110vw; opacity: 1; transform: rotate(-5deg); }
  }

  /* --- Drifting sparkles --- */
  .drift-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .drift {
    position: absolute;
    bottom: -30px;
    font-size: 14px;
    opacity: 0;
    animation: drift-up linear infinite;
  }
  @keyframes drift-up {
    0% { transform: translateY(0) rotate(0); opacity: 0; }
    10% { opacity: 0.7; }
    90% { opacity: 0.7; }
    100% { transform: translateY(-110vh) rotate(360deg); opacity: 0; }
  }

  /* --- Slime drip --- */
  #slime-layer {
    position: fixed;
    inset: 0 0 auto 0;
    height: 0;
    pointer-events: none;
    z-index: 4;
  }
  .slime-drop {
    position: absolute;
    top: -20px;
    width: 40px;
    background: radial-gradient(ellipse at center, #7be87a 0%, #4ac94a 60%, #2fa82f 100%);
    border-radius: 0 0 50% 50% / 0 0 20% 20%;
    box-shadow: 0 0 12px #4ac94a;
    transform-origin: top center;
    animation: slime-drip 5s ease-in forwards;
  }
  @keyframes slime-drip {
    0% { height: 0; }
    100% { height: 100vh; }
  }

  /* --- First-visit confetti --- */
  .confetti-piece {
    position: fixed;
    top: -20px;
    width: 12px;
    height: 12px;
    z-index: 9997;
    pointer-events: none;
    animation: confetti-fall 3s ease-in forwards;
  }
  @keyframes confetti-fall {
    0% { transform: translateY(0) rotate(0); opacity: 1; }
    100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
  }
</style>

<script>
  // ============================================
  // 1. Typed welcome
  // ============================================
  const typedEl = document.querySelector<HTMLElement>(".typed");
  if (typedEl) {
    const text = typedEl.dataset.text ?? "";
    let i = 0;
    const tick = () => {
      if (i <= text.length) {
        typedEl.textContent = text.slice(0, i++);
        setTimeout(tick, 55 + Math.random() * 40);
      } else {
        typedEl.classList.add("done");
      }
    };
    setTimeout(tick, 300);
  }

  // ============================================
  // 2. First-visit confetti
  // ============================================
  function shootConfetti(count = 60) {
    const colors = ["#ff4fa3", "#ffb6d9", "#ffd9ec", "#d6b8ff", "#fff", "#ffe066"];
    const shapes = ["♡", "★", "✨", "🎀", "●"];
    for (let i = 0; i < count; i++) {
      const c = document.createElement("span");
      c.className = "confetti-piece";
      const useShape = Math.random() > 0.4;
      if (useShape) {
        c.textContent = shapes[Math.floor(Math.random() * shapes.length)];
        c.style.width = "auto";
        c.style.height = "auto";
        c.style.fontSize = (14 + Math.random() * 14) + "px";
        c.style.color = colors[Math.floor(Math.random() * colors.length)];
      } else {
        c.style.background = colors[Math.floor(Math.random() * colors.length)];
        c.style.borderRadius = Math.random() > 0.5 ? "50%" : "2px";
      }
      c.style.left = Math.random() * 100 + "vw";
      c.style.animationDuration = (2.2 + Math.random() * 1.8) + "s";
      c.style.animationDelay = (Math.random() * 0.4) + "s";
      document.body.appendChild(c);
      setTimeout(() => c.remove(), 5000);
    }
  }
  if (!sessionStorage.getItem("welcomed")) {
    sessionStorage.setItem("welcomed", "1");
    setTimeout(() => shootConfetti(80), 400);
  }

  // ============================================
  // 3. Drifting sparkles background
  // ============================================
  const driftLayer = document.querySelector<HTMLElement>(".drift-layer");
  if (driftLayer) {
    const driftChars = ["♡", "✨", "⭐", "🎀", "·"];
    for (let i = 0; i < 20; i++) {
      const s = document.createElement("span");
      s.className = "drift";
      s.textContent = driftChars[Math.floor(Math.random() * driftChars.length)];
      s.style.left = Math.random() * 100 + "%";
      s.style.fontSize = (10 + Math.random() * 16) + "px";
      s.style.animationDuration = (12 + Math.random() * 18) + "s";
      s.style.animationDelay = (Math.random() * 15) + "s";
      driftLayer.appendChild(s);
    }
  }

  // ============================================
  // 4. Click-to-cycle characters
  // ============================================
  document.querySelectorAll<HTMLImageElement>(".clickable-char").forEach((el) => {
    el.addEventListener("click", () => {
      const imgs = JSON.parse(el.dataset.images ?? "[]") as string[];
      let idx = parseInt(el.dataset.index ?? "0", 10);
      idx = (idx + 1) % imgs.length;
      el.dataset.index = String(idx);
      el.src = imgs[idx];
      // tiny sparkle pop
      const rect = el.getBoundingClientRect();
      for (let i = 0; i < 6; i++) {
        const s = document.createElement("span");
        s.className = "sparkle";
        s.textContent = "✨";
        s.style.left = (rect.left + rect.width / 2 + (Math.random() - 0.5) * 80) + "px";
        s.style.top = (rect.top + rect.height / 2 + (Math.random() - 0.5) * 80) + "px";
        document.body.appendChild(s);
        setTimeout(() => s.remove(), 800);
      }
    });
  });

  // ============================================
  // 5. Rollerskating Pusheen (every 45s)
  // ============================================
  const skater = document.getElementById("skater");
  function skate() {
    if (!skater) return;
    skater.classList.remove("zoom");
    void skater.offsetWidth;
    skater.classList.add("zoom");
  }
  setTimeout(skate, 10000);
  setInterval(skate, 45000);

  // ============================================
  // 6. Type "slime" or "pusheen" secret codes
  // ============================================
  let buffer = "";
  document.addEventListener("keydown", (e) => {
    if (e.key.length !== 1) return;
    buffer = (buffer + e.key.toLowerCase()).slice(-12);
    if (buffer.endsWith("slime")) {
      slimeDrip();
      buffer = "";
    }
    if (buffer.endsWith("pusheen")) {
      pusheenStampede();
      buffer = "";
    }
  });
  function slimeDrip() {
    const layer = document.getElementById("slime-layer");
    if (!layer) return;
    const count = 12;
    for (let i = 0; i < count; i++) {
      const d = document.createElement("div");
      d.className = "slime-drop";
      d.style.left = (i * (100 / count) + Math.random() * 4) + "vw";
      d.style.width = (30 + Math.random() * 30) + "px";
      d.style.animationDuration = (3 + Math.random() * 4) + "s";
      d.style.animationDelay = (Math.random() * 1.2) + "s";
      layer.appendChild(d);
      setTimeout(() => d.remove(), 9000);
    }
  }
  function pusheenStampede() {
    const pusheens = ["/images/pusheen-1.gif", "/images/pusheen-2.gif", "/images/pusheen-3.gif", "/images/pusheen-4.gif"];
    for (let i = 0; i < 20; i++) {
      const p = document.createElement("img");
      p.src = pusheens[i % pusheens.length];
      p.style.position = "fixed";
      p.style.bottom = (20 + Math.random() * 200) + "px";
      p.style.left = "-120px";
      p.style.width = (50 + Math.random() * 40) + "px";
      p.style.zIndex = "9996";
      p.style.pointerEvents = "none";
      p.style.transition = "left 3s linear";
      document.body.appendChild(p);
      setTimeout(() => { p.style.left = "110vw"; }, 20 + i * 100);
      setTimeout(() => p.remove(), 4500 + i * 100);
    }
  }

  // ============================================
  // 7. Hidden hearts scavenger hunt
  // ============================================
  const foundHearts = new Set<string>();
  const progressEl = document.getElementById("heart-progress");
  document.querySelectorAll<HTMLElement>(".hidden-heart").forEach((h) => {
    h.addEventListener("click", (e) => {
      e.stopPropagation();
      const id = h.dataset.id;
      if (!id || foundHearts.has(id)) return;
      foundHearts.add(id);
      h.classList.add("found");
      if (progressEl) progressEl.textContent = `${foundHearts.size} / 3 found`;
      if (foundHearts.size === 3) {
        setTimeout(() => {
          shootConfetti(120);
          if (progressEl) progressEl.textContent = "💖 you found them all! 💖";
        }, 300);
      }
    });
  });

  // ============================================
  // 8. Magic 8-ball: ask pusheen
  // ============================================
  const answers = [
    "absolutely! 🎀",
    "meow meow yes 🐱",
    "100% yes ✨",
    "definitely!!",
    "hmm... maybe",
    "ask pusheen again later",
    "the capybara says no 🦫",
    "no way jose",
    "it is certain ⭐",
    "pusheen is napping, try later 💤",
    "yes, but only if there's slime",
    "signs point to yes!",
    "nope, nope, nopity nope",
    "🎀 obviously 🎀",
    "ask your pillow",
  ];
  const ansEl = document.getElementById("magic8-answer");
  const qEl = document.getElementById("magic8-q") as HTMLInputElement | null;
  const btn = document.getElementById("magic8-btn");
  function ask() {
    if (!ansEl || !qEl) return;
    if (!qEl.value.trim()) {
      ansEl.textContent = "you gotta ask me something first! 🎀";
      return;
    }
    ansEl.classList.remove("shake");
    void ansEl.offsetWidth;
    ansEl.classList.add("shake");
    ansEl.textContent = "🔮 thinking...";
    setTimeout(() => {
      ansEl.textContent = answers[Math.floor(Math.random() * answers.length)];
    }, 700);
  }
  btn?.addEventListener("click", ask);
  qEl?.addEventListener("keydown", (e) => { if (e.key === "Enter") ask(); });
</script>
