---
import Layout from "../layouts/Layout.astro";
import { sortedVideos } from "../data/videos";

const videos = sortedVideos();
---
<Layout title="claire ♡ studio">
  <section class="hero">
    <img class="hero-pusheen" src="/images/pusheen-3.gif" alt="" />
    <div class="hero-text">
      <h1>welcome to<br/>claire's studio!<span class="sparkle-emoji">✨</span></h1>
      <p>slime, drawing, and all the fun stuff</p>
    </div>
    <img class="hero-capybara" src="/images/capybara-2.gif" alt="" />
  </section>

  <section class="videos">
    <h2>🎬 my videos</h2>
    <div class="grid">
      {videos.map((v) => (
        <a href={`/videos/${v.slug}`} class="card">
          <div class="thumb">
            <img
              src={`https://img.youtube.com/vi/${v.youtubeId}/mqdefault.jpg`}
              alt={v.title}
              loading="lazy"
            />
            <span class="play">▶</span>
          </div>
          <div class="card-body">
            <h3>{v.title}</h3>
            <p class="desc">{v.description}</p>
            <p class="date">{new Date(v.date).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</p>
          </div>
          <span class="bow">🎀</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, #FFE8F3 0%, #FFC4DE 100%);
    border-radius: 24px;
    padding: 2rem 1.5rem;
    margin: 1rem 0 2.5rem;
    border: 3px dashed var(--pink-accent);
    position: relative;
    overflow: hidden;
  }
  .hero::before, .hero::after {
    content: "⭐";
    position: absolute;
    font-size: 1.5rem;
    opacity: 0.5;
  }
  .hero::before { top: 10px; left: 20px; }
  .hero::after { bottom: 10px; right: 20px; }
  .hero-pusheen, .hero-capybara {
    width: 110px;
    height: auto;
  }
  .hero-text { text-align: center; }
  .hero-text h1 {
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    line-height: 1.1;
    color: var(--pink-accent);
    text-shadow: 3px 3px 0 #fff;
  }
  .sparkle-emoji { display: inline-block; animation: spin 4s linear infinite; margin-left: 0.25rem; }
  @keyframes spin {
    from { transform: rotate(0); }
    to { transform: rotate(360deg); }
  }
  .hero-text p {
    font-family: "Fredoka", sans-serif;
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0;
  }
  @media (max-width: 640px) {
    .hero { grid-template-columns: 1fr; text-align: center; }
    .hero-pusheen, .hero-capybara { width: 90px; margin: 0 auto; }
    .hero-text h1 { font-size: 1.8rem; }
  }

  .videos h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .card {
    background: var(--cream);
    border-radius: 20px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border: 3px solid var(--pink-bubble);
    box-shadow: 0 6px 0 var(--pink-accent);
    transition: transform 150ms ease, box-shadow 150ms ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-4px) rotate(-1deg);
    box-shadow: 0 10px 0 var(--pink-accent);
  }
  .card:hover .bow { transform: rotate(15deg) scale(1.3); }
  .thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    opacity: 0.85;
  }
  .card-body { padding: 1rem 1.1rem 1.2rem; flex: 1; }
  .card-body h3 {
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
    color: var(--pink-accent);
  }
  .desc {
    font-size: 0.9rem;
    margin: 0 0 0.6rem;
    color: var(--ink);
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .date {
    font-size: 0.8rem;
    margin: 0;
    font-family: "Fredoka", sans-serif;
    color: var(--pink-accent);
    opacity: 0.75;
  }
  .bow {
    position: absolute;
    top: -8px;
    right: -8px;
    font-size: 1.8rem;
    transition: transform 200ms ease;
  }
</style>
